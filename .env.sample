# Copy this file to .env and fill in your local runtime values.
# Do not commit .env.

# Docker/Compose deployment
NOVEL_REPORT_SCANNER_IMAGE=ghcr.io/congyoubanmian/novel-report-scanner:main
PUID=1000
PGID=1000
CONTAINER_MEMORY_LIMIT=2g
CONTAINER_MEMORY_RESERVATION=512m

# Model/API
BASE_URL=https://your-openai-compatible-endpoint/v1
MODEL_NAME=your-model-name
API_KEY=sk-your-key
# API_KEY_POOL=sk-key-1,sk-key-2
# Keep this enabled in Docker unless you intentionally only need Web UI without scan capability.
NOVEL_REPORT_SCANNER_REQUIRE_API_KEY=1

# Scan profile and throughput
ANALYSIS_PROFILE=harem
# Optional external local novel directory. Leave empty to use ./novels.
NOVELS_DIR=
MAX_WORKERS=2
RPM_LIMIT=100
TPM_LIMIT=10000000
RATE_LIMIT_SCOPE=auto
# 单次请求遇到模型网关 500/502/503/504 时的重试次数；默认快速失败交给断点补扫
API_SERVER_ERROR_MAX_RETRIES=2
# 输入超过该字符数的大请求遇到 500/502/503/504 时只试 1 次后交给降载切分；0 表示关闭
API_SERVER_ERROR_FAST_FAIL_INPUT_CHARS=20000
# 后宫/男性向角色首扫分块大小；调小可降低 504 风险，但会增加块数
HAREM_SCAN_CHUNK_SIZE=7000
# 后宫/男性向角色首扫单块最大输出 tokens；调小可降低网关超时和 JSON 截断风险
HAREM_SCAN_MAX_TOKENS=3000
# 后宫补漏扫描并发；单 Key 或 504 频繁时建议保持 1
HAREM_SCAN_RETRY_WORKERS=1
# 后宫单块遇到 504/timeout/context overflow 后自动切半降载的最大深度；0 表示关闭
HAREM_SCAN_API_DOWNSHIFT_MAX_DEPTH=1
# 小于该字符数的后宫片段不再切半，避免过度碎片化
HAREM_SCAN_API_DOWNSHIFT_MIN_CHARS=1200
# 通用/专项剧情扫描基础片段预算；长篇会自动提高，超出预算时默认内容感知抽样；0 表示不限制
GENERAL_SCAN_MAX_CHUNKS=80
# 通用/专项角色识别每个片段最多输出的核心角色数；调小可降低 504 和 JSON 截断风险
GENERAL_CHARACTER_MAX_PER_CHUNK=12
# 通用/专项角色识别遇到 504/timeout 后自动切半降载的最大深度；0 表示关闭
GENERAL_CHARACTER_API_DOWNSHIFT_MAX_DEPTH=1
# 小于该字符数的通用角色识别片段不再切半，避免过度碎片化
GENERAL_CHARACTER_API_DOWNSHIFT_MIN_CHARS=4000
# 通用/专项剧情扫描低密度片段轻量抽取；1=开启，0=关闭
GENERAL_SCAN_SMART_DENSITY=1
# 通用/专项剧情扫描内容感知抽样；1=长篇优先保留高信号片段并兼顾时间线，0=均匀抽样
GENERAL_SCAN_CONTENT_AWARE_SAMPLING=1
# 通用/专项剧情扫描 chunk hash 增量复用；1=复用未变片段，0=每次全量重扫
GENERAL_SCAN_INCREMENTAL_REUSE=1
# 通用/专项剧情扫描写作质量、节奏和信息密度分析；1=开启，0=关闭以降低成本
GENERAL_SCAN_WRITING_QUALITY=1
# 通用/专项剧情扫描叙事结构和大纲架构分析；1=开启，0=关闭以降低成本
GENERAL_SCAN_NARRATIVE_ARCHITECTURE=1
# 通用/专项剧情扫描伏笔工程追踪；1=开启，0=关闭以降低成本
GENERAL_SCAN_FORESHADOWING_ENGINEERING=1
# 通用/专项剧情扫描中文深层语义、潜台词、读者效果和技法层分析；1=开启，0=关闭以降低成本
GENERAL_SCAN_SEMANTIC_LAYERS=1
# 通用/专项剧情扫描读者体验、爽虐点和期待管理分析；1=开启，0=关闭以降低成本
GENERAL_SCAN_READER_EXPERIENCE=1
# 通用/专项剧情扫描整书连续性与一致性审计；1=开启，0=关闭以降低总评 prompt 成本
GENERAL_SCAN_CONTINUITY_AUDIT=1
# 通用/专项剧情扫描跨片段滚动上下文；1=开启，0=关闭。开启时会禁用 chunk 级增量复用，只复用完全新鲜的整份 summary
GENERAL_SCAN_ROLLING_CONTEXT=1
# 通用/专项剧情扫描全书实体候选预扫描；1=开启，0=关闭。候选仅用于片段抽取提示，不作为确认事实
GENERAL_SCAN_ENTITY_PRESCAN=1
# 通用/专项剧情扫描知识库大模型语义合并；1=开启，0=关闭。开启会多一次 LLM 调用，默认关闭以控制成本
GENERAL_SCAN_KNOWLEDGE_BASE_LLM_MERGE=0
# 滚动上下文注入 prompt 的最大字符数；0 表示关闭上下文注入
GENERAL_SCAN_CONTEXT_MAX_CHARS=1600
HAREM_PLUS_GENERAL_SCAN=0

# Logging
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Advanced scan tuning
DIM_BOOST_MAX_PER_CHUNK=3
RESCAN_ROUNDS=3
MAX_MIDDLE_SUMMARY_CALLS=10
INITIAL_SCAN_BLOCK_MULTIPLIER=3
INITIAL_SCAN_MIN_BLOCK_SIZE=6
RESCAN_MAX_HITS=4
RESCAN_PRE_FILTER_THRESHOLD=1.0
RESCAN_MAX_WINDOW=2000
RESCAN_MAX_PROMPT_HEROINES=4
# 同一 chunk 多次因模型 JSON 截断/不平衡失败后，后续补扫轮跳过它；0 表示不跳过
RESCAN_SKIP_CHRONIC_PARSE_FAILURE_AFTER=2

# Web server
WEB_HOST=0.0.0.0
WEB_PORT=8765
WEB_CORS_ALLOW_ORIGIN=*
# Required by Docker entrypoint unless WEB_ALLOW_NO_AUTH=1 is explicitly set.
WEB_ACCESS_TOKEN=
# Set to 1 only for trusted local-only deployments without a public network path.
WEB_ALLOW_NO_AUTH=0
WEB_REQUEST_TIMEOUT=60
SCAN_CANCEL_TIMEOUT_SECONDS=5
SCAN_HEARTBEAT_INTERVAL_SECONDS=10
# 运行中的扫描进程无任何日志输出超过该秒数后自动终止；0 表示关闭
SCAN_STALL_TIMEOUT_SECONDS=1200
# 扫描进程内部线程池超过该秒数没有任何任务完成时终止当前阶段；默认关闭，线上排查卡死时可设为 600-1800
SCAN_FUTURE_STALL_TIMEOUT_SECONDS=0
MAX_UPLOAD_SIZE=104857600
MAX_JSON_BODY_SIZE=65536
FILE_RESPONSE_CHUNK_SIZE=1048576
SYNC_BOOKS_TTL_SECONDS=5
OUTPUTS_CACHE_TTL_SECONDS=5
SSE_STATE_INTERVAL_SECONDS=3
SSE_SYNC_INTERVAL_SECONDS=5
SSE_MAX_CONNECTION_SECONDS=300
STORAGE_HEALTH_TTL_SECONDS=10

# Copy this file to .env and fill in your local runtime values.
# Do not commit .env.

# Docker/Compose deployment
NOVEL_REPORT_SCANNER_IMAGE=ghcr.io/congyoubanmian/novel-report-scanner:main
PUID=1000
PGID=1000
CONTAINER_MEMORY_LIMIT=2g
CONTAINER_MEMORY_RESERVATION=512m

# Model/API
BASE_URL=https://your-openai-compatible-endpoint/v1
MODEL_NAME=your-model-name
API_KEY=sk-your-key
# API_KEY_POOL=sk-key-1,sk-key-2
# Keep this enabled in Docker unless you intentionally only need Web UI without scan capability.
NOVEL_REPORT_SCANNER_REQUIRE_API_KEY=1

# Scan profile and throughput
ANALYSIS_PROFILE=harem
MAX_WORKERS=2
RPM_LIMIT=100
TPM_LIMIT=10000000
RATE_LIMIT_SCOPE=auto
# 通用/专项剧情扫描基础片段预算；长篇会自动提高，超出预算时按全书均匀抽样；0 表示不限制
GENERAL_SCAN_MAX_CHUNKS=80
HAREM_PLUS_GENERAL_SCAN=0

# Advanced scan tuning
DIM_BOOST_MAX_PER_CHUNK=3
RESCAN_ROUNDS=3
MAX_MIDDLE_SUMMARY_CALLS=10
INITIAL_SCAN_BLOCK_MULTIPLIER=3
INITIAL_SCAN_MIN_BLOCK_SIZE=6
RESCAN_MAX_HITS=4
RESCAN_PRE_FILTER_THRESHOLD=1.0
RESCAN_MAX_WINDOW=2000
RESCAN_MAX_PROMPT_HEROINES=4

# Web server
WEB_HOST=0.0.0.0
WEB_PORT=8765
WEB_CORS_ALLOW_ORIGIN=*
# Optional. When set, API/files/SSE/upload require this token.
WEB_ACCESS_TOKEN=
WEB_REQUEST_TIMEOUT=60
MAX_UPLOAD_SIZE=104857600
MAX_JSON_BODY_SIZE=65536
FILE_RESPONSE_CHUNK_SIZE=1048576
SYNC_BOOKS_TTL_SECONDS=5
OUTPUTS_CACHE_TTL_SECONDS=5
SSE_STATE_INTERVAL_SECONDS=3
SSE_SYNC_INTERVAL_SECONDS=5
SSE_MAX_CONNECTION_SECONDS=300

BASE_URL=https://api.deepseek.com
MODEL_NAME=deepseek-chat

# 分析模式：auto=按每本书自动识别；harem=后宫/男性向排雷；general=通用；history=历史小说；hard_sci_fi=硬科幻
ANALYSIS_PROFILE=harem

# 小说目录；留空默认读取项目内 novels/。本机外部样本可设为 /home/ctyun/workspace/novel
NOVELS_DIR=

# 并发和本地预限流
MAX_WORKERS=3
RPM_LIMIT=10
TPM_LIMIT=100000
# 本地限流作用域：auto=多key时每key计数、单key时全局计数；global=所有线程/key共用一个桶；per_key=每个key单独计数
RATE_LIMIT_SCOPE=auto

# 同一请求遇到模型网关 500/502/503/504 时最多重试次数；504 频繁时保持较小值，交给断点补扫
API_SERVER_ERROR_MAX_RETRIES=2

# 后宫/男性向角色首扫分块大小。调小可降低单请求 token 和 504 风险，但会增加分块数
HAREM_SCAN_CHUNK_SIZE=7000

# 后宫/男性向角色首扫单块最大输出 tokens。调小可降低网关超时和 JSON 截断风险
HAREM_SCAN_MAX_TOKENS=3000

# 后宫补漏扫描并发；单 Key 或 504 频繁时建议保持 1
HAREM_SCAN_RETRY_WORKERS=1

# 每个片段最多做多少次“维度补抽”；越大越积极补抽，但额外调用也可能更多，最大为5，数值为0-5
DIM_BOOST_MAX_PER_CHUNK=1

# 扫描结束后最多补扫几轮遗漏或失败片段；越大越稳，但整体耗时更长
RESCAN_ROUNDS=3

# 扫描过程中最多额外生成多少次“中间上下文摘要”；越大越利于承接上下文，但会增加额外调用
MAX_MIDDLE_SUMMARY_CALLS=10

# 首扫动态线程块数量倍率；默认 3 表示把 chunk 切成约 worker 数 3 倍的小连续块，便于快线程继续领取后续块
INITIAL_SCAN_BLOCK_MULTIPLIER=3

# 首扫动态线程块的目标最小块大小；值越小越均衡，但段边界补扫和摘要开销会更多
INITIAL_SCAN_MIN_BLOCK_SIZE=6

# 全局补扫里每个“女主+维度”最多保留多少个候选命中片段；越大越容易补到遗漏，但额外扫描也会更多，设置为0不开启
RESCAN_MAX_HITS=4

# 全局补扫对候选命中的最低预过滤分数；越高越严格，进入后续补扫的片段越少
RESCAN_PRE_FILTER_THRESHOLD=1.0

# 全局补扫截取聚类窗口时允许的最大文本长度；越大上下文更完整，但 prompt 也会更长
RESCAN_MAX_WINDOW=2000

# 单次全局补扫 prompt 最多带多少名女主；越大覆盖人物更多，但 prompt 会更拥挤
RESCAN_MAX_PROMPT_HEROINES=4

# 通用小说分析模式下使用：基础扫描片段预算；程序会按长度自动提高到 120/160/300/400；0 表示不限制
# 超出预算时按全书时间线均匀抽样，不只扫描开头
GENERAL_SCAN_MAX_CHUNKS=80
# 通用/专项剧情扫描低密度片段轻量抽取；1=开启，0=关闭
GENERAL_SCAN_SMART_DENSITY=1
# 通用/专项剧情扫描 chunk hash 增量复用；1=复用未变片段，0=每次全量重扫
GENERAL_SCAN_INCREMENTAL_REUSE=1
# 通用/专项剧情扫描全书实体候选预扫描；1=开启，0=关闭。候选仅用于片段抽取提示
GENERAL_SCAN_ENTITY_PRESCAN=1

# 后宫增强模式：1=后宫排雷后额外运行通用剧情扫描，并在报告末尾追加作品整体评价；0=关闭
HAREM_PLUS_GENERAL_SCAN=0

# 扫描日志轮转：单个日志文件最大字节数与保留历史份数；0 表示不轮转
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Web 层扫描进程无日志输出超过该秒数后自动终止；0 表示关闭
SCAN_STALL_TIMEOUT_SECONDS=1200

# 扫描进程内部线程池超过该秒数没有任何任务完成时终止当前阶段；默认关闭，线上排查卡死时可设为 600-1800
SCAN_FUTURE_STALL_TIMEOUT_SECONDS=0

# Web 存储写入自检缓存时间；状态页/SSE 频繁刷新时减少挂载卷临时写入，0 表示每次都重新探测
STORAGE_HEALTH_TTL_SECONDS=10

# Web 管理端可选访问令牌；留空不启用。公网部署建议设置一个长随机字符串。
WEB_ACCESS_TOKEN=

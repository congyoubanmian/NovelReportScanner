{
  "extends": "_base_general",
  "name": "xianxia_fantasy",
  "sort_order": 50,
  "display_name": "仙侠/玄幻专长分析",
  "description": "在通用小说分析基础上，重点检查修炼体系、血脉体质、宗门势力、法宝功法、东方神话元素、求道主题和升级爽点是否自洽。",
  "cross_profile_rules": {
    "harem": {
      "import_categories": [
        "雷点（严重毒点）",
        "郁闷点"
      ],
      "import_points": [
        "绿帽",
        "死女",
        "送女",
        "前世雷",
        "破鞋/非处/非初",
        "漏女",
        "亵女"
      ]
    }
  },
  "scan_focus": [
    "境界、修炼体系、功法、灵根、血脉、体质和战力层级是否稳定",
    "宗门、家族、王朝、仙界/魔界等势力结构和资源分配逻辑",
    "法宝、丹药、阵法、秘境、传承、机缘与代价是否自洽",
    "血脉、体质、天赋系统（如圣体、灵根、武魂、至尊骨）是否有独立设定和成长代价",
    "东方神话元素（洪荒、封神、西游、天庭等）的融入是否自洽",
    "主角升级节奏、爽点密度、越级战斗和外挂感是否可接受",
    "求道主题、长生动机、心性修炼与实力提升是否同步",
    "世界观扩张、地图切换、下界/上界/仙界等位面设定是否持续影响剧情",
    "常见硬伤：战力崩坏、境界通胀、反派降智、机缘堆砌、设定遗忘"
  ],
  "summary_fields": [
